{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(python:*)", "Bash(python3:*)", "Bash(uv:*)", "Bash(pytest:*)",
      "Bash(ruff:*)", "Bash(make:*)", "Bash(mkdir:*)", "Bash(ls:*)",
      "Bash(cat:*)", "Bash(head:*)", "Bash(tail:*)", "Bash(wc:*)",
      "Bash(git add:*)", "Bash(git commit:*)", "Bash(git status:*)",
      "Bash(git diff:*)", "Bash(git checkout:*)", "Bash(git branch:*)",
      "Bash(docker compose:*)", "Bash(psql:*)",
      "Bash(curl -L https://data.cms.gov/*)",
      "Bash(curl -L https://download.cms.gov/*)",
      "Bash(sha256sum:*)", "Bash(unzip:*)", "Bash(streamlit:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(rm -rf /*)",
      "Read(.env)"
    ]
  }
}
